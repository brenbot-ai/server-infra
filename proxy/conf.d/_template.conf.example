# [newproject].equityrange.com — template for future projects
# Copy this file to conf.d/newproject.conf, replace NEWPROJECT throughout

server {
    listen 80;
    server_name NEWPROJECT.equityrange.com;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name NEWPROJECT.equityrange.com;

    ssl_certificate     /etc/letsencrypt/live/NEWPROJECT.equityrange.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/NEWPROJECT.equityrange.com/privkey.pem;

    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 1d;

    add_header Strict-Transport-Security "max-age=63072000" always;
    add_header X-Frame-Options SAMEORIGIN;
    add_header X-Content-Type-Options nosniff;

    # Remove auth_basic lines if no password protection needed
    # auth_basic "NEWPROJECT";
    # auth_basic_user_file /etc/nginx/auth/NEWPROJECT.htpasswd;

    location / {
        proxy_pass         http://NEWPROJECT-app:3000;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
